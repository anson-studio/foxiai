{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/proxy/(.*)",
      "destination": "/api/proxy?path=$1"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}
      ]
    }
  ]
}
